THEME=https://raw.githubusercontent.com/seanwcom/Red-Graphite-for-Obsidian/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgShowBacklinks=true
dgShowLocalGraph=false
dgShowInlineTitle=false
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=false
SITE_NAME_HEADER=Droshar
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://droshar.vercel.app/
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=false
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { } body.theme-light.css-settings-manager { --button-background: #0051F2; } body.theme-dark.css-settings-manager { --button-border: #979797; --button-box-shadow: rgb(108,53,170); --button-text: #B78CDC; --button-background: #DF0000; }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager Heading folder-notes-plugin hide-folder-note fn-hide-collapse-icon version-1-7-2 its-theme sidebar-float-bottom folder-arrow-hidden check-color check-bg wotc-beyond img-adj-list is-maximized is-focused
USE_FULL_RESOLUTION_IMAGES=false
dgPassFrontmatter=false